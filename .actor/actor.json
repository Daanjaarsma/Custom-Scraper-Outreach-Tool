{
  "actorSpecification": 1,
  "name": "praedix-cold-outreach-enricher",
  "title": "Praedix Cold Outreach Email Enricher",
  "description": "Scrapt email-adressen en telefoon van bedrijfswebsites voor e-commerce en recruitment leads. Geoptimaliseerd voor snelheid en nauwkeurigheid.",
  "version": "1.0",
  "buildTag": "latest",
  "meta": {
    "templateId": "python-playwright"
  },
  "input": "./input_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "overview": {
          "title": "Enriched Leads",
          "transformation": {
            "fields": [
              "leadId",
              "name",
              "website",
              "primaryEmail",
              "phone",
              "city",
              "address",
              "isReachable",
              "discardReason"
            ]
          },
          "display": {
            "component": "table",
            "properties": {
              "leadId": { "label": "Lead ID", "format": "text" },
              "name": { "label": "Bedrijf", "format": "text" },
              "website": { "label": "Website", "format": "link" },
              "primaryEmail": { "label": "Email", "format": "text" },
              "phone": { "label": "Telefoon", "format": "text" },
              "city": { "label": "Stad", "format": "text" },
              "address": { "label": "Adres", "format": "text" },
              "isReachable": { "label": "Bereikbaar", "format": "boolean" },
              "discardReason": { "label": "Reden overgeslagen", "format": "text" }
            }
          }
        }
      }
    }
  },
  "dockerfile": "../Dockerfile"
}
